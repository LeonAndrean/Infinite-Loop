<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #1C3D2B;"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gereja.chatbot.controller.ForgotPasswordConttroller">

    <VBox>

        <!-- HEADER -->
        <VBox alignment="CENTER"
              spacing="8"
              style="-fx-background-color: #122A1E; -fx-padding: 12;"
              maxWidth="Infinity">

            <Label text="Faith Buddy"
                   style="-fx-text-fill: #f8f8f8; -fx-font-size: 24px; -fx-font-weight: bold;" />

            <Label text="Reset Password Admin"
                   style="-fx-text-fill: #7AAA8A; -fx-font-size: 13px;" />
        </VBox>

        <!-- FORM -->
        <StackPane alignment="CENTER" VBox.vgrow="ALWAYS">

            <VBox alignment="CENTER"
                  spacing="20"
                  maxWidth="440"
                  style="-fx-background-color: #1C3D2B; -fx-padding: 36 40;">

                <!-- USERNAME -->
                <VBox spacing="8">
                    <Label text="Username"
                           style="-fx-text-fill: #9EC4AE; -fx-font-size: 12px; -fx-font-weight: bold;" />

                    <HBox spacing="10"
                          style="-fx-background-color: #142D1F; -fx-padding: 12 16;">

                        <Label text="👤"/>

                        <TextField fx:id="txtUsername"
                                   promptText="Masukkan username"
                                   style="-fx-background-color: transparent; -fx-text-fill: #E8F0EB; -fx-prompt-text-fill: #4A7A5A;"
                                   maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- PASSWORD BARU -->
                <VBox spacing="8">
                    <Label text="Password Baru"
                           style="-fx-text-fill: #9EC4AE; -fx-font-size: 12px; -fx-font-weight: bold;" />

                    <HBox spacing="10"
                          style="-fx-background-color: #142D1F; -fx-padding: 12 16;">

                        <Label text="🔒"/>

                        <PasswordField fx:id="txtNewPassword"
                                       promptText="Masukkan password baru"
                                       style="-fx-background-color: transparent; -fx-text-fill: #E8F0EB;"
                                       maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- KONFIRMASI -->
                <VBox spacing="8">
                    <Label text="Konfirmasi Password"
                           style="-fx-text-fill: #9EC4AE; -fx-font-size: 12px; -fx-font-weight: bold;" />

                    <HBox spacing="10"
                          style="-fx-background-color: #142D1F; -fx-padding: 12 16;">

                        <Label text="🔐"/>

                        <PasswordField fx:id="txtConfirmPassword"
                                       promptText="Ulangi password"
                                       style="-fx-background-color: transparent; -fx-text-fill: #E8F0EB;"
                                       maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- INFO -->
                <Label fx:id="lblInfo"
                       text=""
                       style="-fx-text-fill: #E05A5A; -fx-font-size: 12px;" />

                <!-- BUTTON -->
                <Button text="RESET PASSWORD"
                        onAction="#handleReset"
                        prefHeight="45"
                        maxWidth="Infinity"
                        style="-fx-background-color: #D4A843; -fx-text-fill: #1C3D2B; -fx-font-weight: bold; -fx-font-size: 14px;" />

                <!-- BACK -->
                <Hyperlink text="Kembali ke Login"
                           onAction="#handleBack"
                           style="-fx-text-fill: #7AAA8A;" />

            </VBox>

        </StackPane>

    </VBox>
</StackPane>