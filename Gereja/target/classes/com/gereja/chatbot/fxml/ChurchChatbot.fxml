<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720" prefWidth="1100" style="-fx-background-color: #F2EEE9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gereja.chatbot.controller.ChatbotController">

    <!-- ================= COLLAPSIBLE SIDEBAR ================= -->
    <left>
        <VBox fx:id="sidebar" managed="true" prefWidth="250.0" style="-fx-background-color: #122A1E; -fx-padding: 20 15; -fx-spacing: 12;" visible="true">
            <children>
                <!-- TOP HEADER -->
                <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 15 0; -fx-border-color: #2D5A3D; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Label style="-fx-text-fill: #f8f8f8; -fx-font-size: 22px; -fx-font-weight: bold;" text="Faith Buddy" />
                        <Label style="-fx-text-fill: #7AAA8A; -fx-font-size: 11px;" text="Asisten Chatbot" />
                    </children>
                </VBox>

                <!-- NAVIGATION MENUS -->
                <VBox spacing="10" style="-fx-padding: 15 0 0 0;" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Kalender -->
                        <HBox onMouseClicked="#handleMenuKalender" onMouseEntered="#onSidebarItemHover" onMouseExited="#onSidebarItemExit" style="-fx-padding: 11 16; -fx-background-radius: 10; -fx-cursor: hand; -fx-spacing: 10; -fx-alignment: center-left;">
                            <children>
<!--                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px;" text="" />-->
                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 13px;" text="🗓 Kalender" />
                            </children>
                        </HBox>

                        <!-- About Us -->
                        <HBox onMouseClicked="#handleMenuAboutUs" onMouseEntered="#onSidebarItemHover" onMouseExited="#onSidebarItemExit" style="-fx-padding: 11 16; -fx-background-radius: 10; -fx-cursor: hand; -fx-spacing: 10; -fx-alignment: center-left;">
                            <children>
<!--                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px;" text="" />-->
                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 13px;" text="ℹ About Us" />
                            </children>
                        </HBox>

                        <!-- Settings -->
                        <HBox onMouseClicked="#handleOpenSettings" onMouseEntered="#onSidebarItemHover" onMouseExited="#onSidebarItemExit" style="-fx-padding: 11 16; -fx-background-radius: 10; -fx-cursor: hand; -fx-spacing: 10; -fx-alignment: center-left;">
                            <children>
<!--                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px;" text="⚙️" />-->
                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 13px;" text="⚙ Setting" />
                            </children>
                        </HBox>

                        <!-- Admin Login -->
                        <HBox onMouseClicked="#handleAdminLoginFromSidebar" onMouseEntered="#onSidebarItemHover" onMouseExited="#onSidebarItemExit" style="-fx-padding: 11 16; -fx-background-radius: 10; -fx-cursor: hand; -fx-spacing: 10; -fx-alignment: center-left;">
                            <children>
<!--                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px;" text="👤" />-->
                                <Label style="-fx-text-fill: #E8F0EB; -fx-font-size: 13px;" text="👤 Admin Login" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- BOTTOM MENUS -->
                <VBox spacing="8" style="-fx-border-color: #2D5A3D; -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
                    <children>
                        <!-- Back to Landing -->
                        <HBox onMouseClicked="#handleBackToLanding" onMouseEntered="#onSidebarExitHover" onMouseExited="#onSidebarItemExit" style="-fx-padding: 11 16; -fx-background-radius: 10; -fx-cursor: hand; -fx-spacing: 10; -fx-alignment: center-left;">
                            <children>
<!--                                <Label style="-fx-text-fill: #ff9999; -fx-font-size: 14px; -fx-font-weight: bold;" text="↩" />-->
                                <Label style="-fx-text-fill: #ff9999; -fx-font-size: 13px; -fx-font-weight: bold;" text="↩ Back" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- ================= CENTER CHAT INTERFACE ================= -->
    <center>
        <VBox style="-fx-background-color: #F2EEE9;">

            <HBox fx:id="menuBeranda" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 20;                          -fx-border-color: #DDD6CC; -fx-border-width: 0 0 1 0;">

                <Button onAction="#handleToggleSidebar" style="-fx-background-color: transparent; -fx-text-fill: #1A3A2A;                                -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 15 0 0;" text="☰" />

                <GridPane prefHeight="50.0" HBox.hgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="38.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="0.0" prefWidth="110.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints maxHeight="50.0" minHeight="5.0" prefHeight="10.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="50.0" minHeight="0.0" prefHeight="26.0" vgrow="SOMETIMES" />
                        <RowConstraints maxHeight="31.0" minHeight="0.0" prefHeight="16.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label style="-fx-font-size: 22px; -fx-text-fill: #D4A843;" text="+" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A; -fx-padding: 0 0 0 8;" text="Faith Buddy" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>

                        <Label style="-fx-text-fill: #7A8A7A; -fx-font-size: 11px; -fx-padding: 0 0 0 8;" text="Asisten Informasi Gereja" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <HBox alignment="CENTER_RIGHT" spacing="6" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <Label style="-fx-text-fill: #4CAF50; -fx-font-size: 10px;" />
                            <Label style="-fx-text-fill: #7A8A7A; -fx-font-size: 11px;" />
                        </HBox>
                    </children>
                </GridPane>
            </HBox>

            <VBox fx:id="ayatHarianBox" style="-fx-background-color: #1A3A2A; -fx-padding: 12 20 10 20;                          -fx-border-color: #D4A843; -fx-border-width: 0 0 2 0;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-text-fill: #D4A843; -fx-font-size: 14px;" text="*" />
                    <Label style="-fx-text-fill: #D4A843; -fx-font-size: 10px;                                   -fx-font-weight: bold;" text="FIRMAN TUHAN HARI INI" />
                    <Label style="-fx-text-fill: #D4A843; -fx-font-size: 14px;" text="*" />
                </HBox>
                <Label fx:id="lblAyatReferensi" style="-fx-text-fill: #F5D882; -fx-font-size: 12px;                               -fx-font-weight: bold; -fx-padding: 4 0 0 0;" text="" />
                <Label fx:id="lblAyatIsi" maxWidth="Infinity" style="-fx-text-fill: #D4EDD9; -fx-font-size: 12px;                               -fx-font-style: italic; -fx-padding: 2 0 0 0;" text="" wrapText="true" />
                <Label fx:id="lblAyatKeterangan" style="-fx-text-fill: #7AAA8A; -fx-font-size: 10px; -fx-padding: 2 0 0 0;" text="" />
            </VBox>

            <StackPane fx:id="chatOverlayPane" VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                    <VBox fx:id="chatContainer" spacing="10" style="-fx-padding: 16 20;" />
                </ScrollPane>
            </StackPane>

            <VBox style="-fx-background-color: white; -fx-border-color: #DDD6CC;                          -fx-border-width: 1 0 0 0; -fx-padding: 10 16;">
                <HBox alignment="CENTER" spacing="10">
                    <HBox alignment="CENTER" style="-fx-background-color: #F2EEE9; -fx-background-radius: 20;                                  -fx-padding: 6 14; -fx-border-color: #DDD6CC;                                  -fx-border-width: 1; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
                        <TextArea fx:id="messageInput" prefRowCount="1" promptText="Ketik pertanyaan Anda (mis: syarat baptis, jam ibadah)..." style="-fx-background-color: transparent; -fx-border-width: 0;                                          -fx-font-size: 13px; -fx-text-fill: #2A2A2A;" HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Button onAction="#sendMessage" style="-fx-background-color: #1A3A2A; -fx-text-fill: #D4A843;                                    -fx-font-size: 13px; -fx-font-weight: bold;                                    -fx-background-radius: 20; -fx-padding: 10 18; -fx-cursor: hand;" text="Kirim" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
