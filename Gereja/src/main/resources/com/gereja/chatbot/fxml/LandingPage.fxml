<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #1C3D2B;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gereja.chatbot.controller.LandingController">

    <VBox maxWidth="Infinity">

        <!-- HEADER -->
        <VBox alignment="CENTER" maxWidth="Infinity" spacing="8" style="-fx-background-color: #122A1E; -fx-padding: 14;">

            <Label style="-fx-text-fill: #f8f8f8;                           -fx-font-size: 24px;                           -fx-font-weight: bold;" text="Faith Buddy" />

            <Label style="-fx-text-fill: #7AAA8A;                           -fx-font-size: 13px;" text="Chatbot Asisten Gereja" />

        </VBox>

        <!-- CONTENT -->
        <StackPane alignment="CENTER" VBox.vgrow="ALWAYS">

            <VBox alignment="CENTER" maxWidth="440" spacing="20" style="-fx-background-color: #1C3D2B;                          -fx-padding: 40 40 40 40;">

<!--                &lt;!&ndash; LOGO &ndash;&gt;-->
<!--                <ImageView fx:id="logoImage"-->
<!--                           fitHeight="120"-->
<!--                           fitWidth="120"-->
<!--                           preserveRatio="true"/>-->

                <!-- DESCRIPTION -->
                <Label maxWidth="320" style="-fx-text-fill: #9EC4AE;                               -fx-font-size: 13px;                               -fx-alignment: center;" text="Teman digital untuk membantu pelayanan dan informasi gereja" textAlignment="CENTER" wrapText="true" />

                <!-- START BUTTON -->
                <Button onAction="#handleStartChat" prefHeight="45" prefWidth="260" style="-fx-background-color: #D4A843;                                -fx-text-fill: #1C3D2B;                                -fx-font-weight: bold;                                -fx-font-size: 14px;                                -fx-background-radius: 5;                                -fx-cursor: hand;" text="MULAI CHAT" />

            </VBox>

        </StackPane>

    </VBox>

</StackPane>
