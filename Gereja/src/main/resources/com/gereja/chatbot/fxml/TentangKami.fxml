<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gereja.chatbot.controller.TentangKamiController"
           style="-fx-background-color: #1C3D2B;">

    <VBox spacing="0" prefWidth="900" prefHeight="600">
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              style="-fx-background-color: #122A1E; -fx-padding: 18 25;">

            <Label text="Tentang Kami"
                   style="-fx-text-fill: white;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <Button text="Kembali"
                    onAction="#handleBack"
                    prefWidth="120"
                    prefHeight="35"
                    style="-fx-background-color: #D4A843;
                           -fx-text-fill: #1C3D2B;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;" />
        </HBox>

        <ScrollPane fitToWidth="true"
                    style="-fx-background: #1C3D2B;
                           -fx-background-color: #1C3D2B;"
                    VBox.vgrow="ALWAYS">

            <VBox spacing="25"
                  alignment="TOP_CENTER"
                  style="-fx-padding: 35;">

                <ImageView fx:id="logoImage"
                           fitHeight="130"
                           fitWidth="130"
                           preserveRatio="true" />

                <VBox alignment="CENTER" spacing="8">
                    <Label text="Faith Buddy"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 30px;
                                  -fx-font-weight: bold;" />

                    <Label text="Chatbot Asisten Gereja"
                           style="-fx-text-fill: #9EC4AE;
                                  -fx-font-size: 15px;" />
                </VBox>

                <VBox spacing="14"
                      maxWidth="680"
                      style="-fx-background-color: #244D36;
                             -fx-background-radius: 8;
                             -fx-padding: 24;">

                    <Label text="Faith Buddy adalah asisten digital yang membantu jemaat mendapatkan informasi pelayanan gereja dengan mudah."
                           wrapText="true"
                           style="-fx-text-fill: #E8F0EB;
                                  -fx-font-size: 15px;" />

                    <Label text="User dapat bertanya secara manual melalui chat tentang jadwal ibadah, pelayanan gereja, ayat harian, kontak, dan informasi lain yang dibutuhkan."
                           wrapText="true"
                           style="-fx-text-fill: #C8DDD0;
                                  -fx-font-size: 14px;" />

                    <Label text="Dikembangkan untuk mendukung pelayanan digital gereja."
                           wrapText="true"
                           style="-fx-text-fill: #D4A843;
                                  -fx-font-size: 14px;
                                  -fx-font-weight: bold;" />
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
