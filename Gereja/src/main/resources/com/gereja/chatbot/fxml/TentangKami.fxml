<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gereja.chatbot.controller.TentangKamiController"
            stylesheets="@../css/styles.css"
            style="-fx-background-color: #1C3D2B;">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox alignment="CENTER"
              spacing="6"
              styleClass="settings-header">
            <HBox alignment="CENTER_LEFT">
                <Button text="←"
                        onAction="#handleBack"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #D4A843;
                               -fx-font-size: 22px;
                               -fx-cursor: hand;" />
            </HBox>
            <Label text="Faith Buddy"
                   style="-fx-text-fill: #f8f8f8;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;" />
            <Label text="Tentang Kami (About Us)"
                   style="-fx-text-fill: #7AAA8A;
                          -fx-font-size: 13px;" />
        </VBox>
    </top>

    <!-- ================= CONTENT ================= -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #1C3D2B;
                           -fx-background-color: transparent;">
            <VBox spacing="20"
                  style="-fx-padding: 24;"
                  alignment="TOP_CENTER">
                <children>
                    <VBox spacing="18"
                          styleClass="settings-card"
                          maxWidth="600"
                          alignment="TOP_LEFT">
                        <children>
                            <Label text="TENTANG APLIKASI"
                                   styleClass="settings-title"/>

                            <Label text="Faith Buddy adalah aplikasi chatbot pintar berbasis JavaFX yang dirancang khusus untuk mempermudah jemaat GKJ Ngupasan Yogyakarta dalam mengakses berbagai layanan gerejawi secara instan dan digital."
                                   wrapText="true"
                                   style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px; -fx-line-spacing: 5;"/>

                            <Label text="APLIKASI INI DAPAT MEMBANTU ANDA:"
                                   style="-fx-text-fill: #D4A843; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 10 0 0 0;"/>

                            <VBox spacing="8" style="-fx-padding: 0 0 0 10;">
                                <children>
                                    <Label text="• ⛪ Mengetahui jadwal ibadah mingguan terdekat &amp; minggu depan secara cerdas." style="-fx-text-fill: #9EC4AE; -fx-font-size: 13px;"/>
                                    <Label text="• 👤 Mengetahui profil pendeta pelayan beserta jadwal konseling &amp; kontak mereka." style="-fx-text-fill: #9EC4AE; -fx-font-size: 13px;"/>
                                    <Label text="• 📋 Melihat persyaratan dokumen dan biaya untuk layanan Baptis, Pernikahan, SIDI, dan Konseling." style="-fx-text-fill: #9EC4AE; -fx-font-size: 13px;"/>
                                    <Label text="• 📅 Melihat kalender kegiatan gerejawi bulanan yang interaktif." style="-fx-text-fill: #9EC4AE; -fx-font-size: 13px;"/>
                                    <Label text="• 💬 Berinteraksi dengan chatbot secara cerdas dan menanyakan dua hal berbeda sekaligus dalam satu bubble teks." style="-fx-text-fill: #9EC4AE; -fx-font-size: 13px;"/>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <VBox spacing="18"
                          styleClass="settings-card"
                          maxWidth="600"
                          alignment="TOP_LEFT">
                        <children>
                            <Label text="TIM PENGEMBANG (DEVELOPERS)"
                                   styleClass="settings-title"/>

                            <Label text="Aplikasi ini dikembangkan oleh Tim Infinite Loop untuk memenuhi revisi kompleksitas tugas dan melayani jemaat dengan dedikasi penuh."
                                   wrapText="true"
                                   style="-fx-text-fill: #E8F0EB; -fx-font-size: 14px; -fx-line-spacing: 5;"/>

                            <VBox spacing="6" style="-fx-padding: 10 0 0 0;">
                                <children>
                                    <Label text="Developer Team:" style="-fx-text-fill: #D4A843; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                                    <Label text="• Infinite Loop Developer Group" style="-fx-text-fill: #E8F0EB; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                    <Label text="• Universitas Kristen Duta Wacana" style="-fx-text-fill: #7AAA8A; -fx-font-size: 12px;"/>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <Button text="KEMBALI KE CHAT"
                            onAction="#handleBack"
                            prefWidth="260"
                            prefHeight="45"
                            styleClass="settings-gold-button"/>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
