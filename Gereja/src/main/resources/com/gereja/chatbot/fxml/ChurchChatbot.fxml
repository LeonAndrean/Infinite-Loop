<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720" prefWidth="1100" style="-fx-background-color: #F5F0EB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gereja.chatbot.controller.ChatbotController">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--                        SIDEBAR                         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #1A3A2A; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 12, 0, 4, 0);">

            <!-- ── Header / Branding ── -->
            <VBox alignment="CENTER" spacing="6" style="-fx-background-color: #122A1E; -fx-padding: 28 20 22 20;">
                <StackPane prefHeight="52" prefWidth="52">
                    <Circle radius="26" style="-fx-fill: #D4A843; -fx-effect: dropshadow(gaussian, rgba(212,168,67,0.4), 8, 0, 0, 0);" />
                    <Rectangle arcHeight="3" arcWidth="3" height="32" style="-fx-fill: #122A1E;" width="6" />
                    <Rectangle arcHeight="3" arcWidth="3" height="6" style="-fx-fill: #122A1E;" translateY="-6" width="22" />
                </StackPane>
                <Label style="-fx-text-fill: #F5F0EB; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Georgia';" text="Faith Buddy" />
                <Label style="-fx-text-fill: #8AB99A; -fx-font-size: 11px; -fx-font-family: 'Georgia';" text="Layanan Informasi Jemaat" />
            </VBox>

            <!-- ── Navigation Menu ── -->
            <VBox spacing="4" style="-fx-padding: 18 12 12 12;">
                <Label style="-fx-text-fill: #5A8A6A; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 6 8; -fx-font-family: 'Verdana';" text="MENU UTAMA" />

                <HBox fx:id="menuBeranda" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #D4A843; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="🏠" />
                    <Label style="-fx-text-fill: #122A1E; -fx-font-size: 13px; -fx-font-weight: bold;" text="Beranda" />
                </HBox>

                <HBox fx:id="menuPembaptisan" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="💧" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Pembaptisan" />
                </HBox>

                <HBox fx:id="menuPernikahan" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="💍" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Pernikahan Gerejawi" />
                </HBox>

                <HBox fx:id="menuSidi" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="📖" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="SIDI / Peneguhan" />
                </HBox>

                <HBox fx:id="menuKonseling" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="🤝" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Konseling Pendeta" />
                </HBox>

                <HBox fx:id="menuJadwal" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="📅" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Jadwal &amp; Pendaftaran" />
                </HBox>

                <Separator style="-fx-padding: 6 0;" />

                <Label style="-fx-text-fill: #5A8A6A; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 6 0 6 8; -fx-font-family: 'Verdana';" text="LAINNYA" />

                <HBox fx:id="menuNotifikasi" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <StackPane>
                        <Label style="-fx-font-size: 16px;" text="🔔" />
                        <Label style="-fx-background-color: #E05252; -fx-text-fill: white; -fx-font-size: 8px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 1 4;" text="3" translateX="8" translateY="-8" />
                    </StackPane>
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Notifikasi" />
                </HBox>

                <HBox fx:id="menuRiwayat" alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent; -fx-background-radius: 10; -fx-padding: 11 16; -fx-cursor: hand;">
                    <Label style="-fx-font-size: 16px;" text="🕐" />
                    <Label style="-fx-text-fill: #C8DDD0; -fx-font-size: 13px;" text="Riwayat Konsultasi" />
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- ── Status Online ── -->
            <VBox style="-fx-background-color: #122A1E; -fx-padding: 14 20;" />

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--                      MAIN CONTENT                      -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #F5F0EB;">

            <!-- ── Top Bar ── -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #FFFFFF; -fx-padding: 16 24; -fx-border-color: #E2DAD0; -fx-border-width: 0 0 1 0;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A; -fx-font-family: 'Georgia';" text="Selamat Datang di Faith Buddy 👋" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7A8A7E;" text="Kami hadir untuk membantu informasi pelayanan gerejawi Anda" />
                </VBox>

                <StackPane>
                    <Circle radius="15.0" style="-fx-fill: #2D5A3D;" />
                    <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="36.0" prefWidth="26.0" rotate="180.0" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="➜]" StackPane.alignment="CENTER">
                        <font>
                            <Font name="System Bold" size="37.0" />
                        </font></Label>
                </StackPane>
            </HBox>

            <!-- ── Chat + Right Panel ── -->
            <HBox spacing="0" VBox.vgrow="ALWAYS">

                <!-- ── Chat Area ── -->
                <VBox spacing="0" HBox.hgrow="ALWAYS">

                    <!-- Chat Messages -->
                    <ScrollPane fx:id="chatScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">

                        <VBox fx:id="chatContainer" spacing="16" style="-fx-padding: 24 28 16 28; -fx-background-color: #F5F0EB;">

                            <!-- ── Welcome Bot Message ── -->
                            <HBox alignment="TOP_LEFT" spacing="12">
                                <StackPane minHeight="40" minWidth="40">
                                    <Circle radius="20" style="-fx-fill: #1A3A2A;" />
                                    <Label style="-fx-text-fill: #D4A843; -fx-font-size: 16px;" text="✝" />
                                </StackPane>
                                <VBox maxWidth="500" spacing="6">
                                    <Label style="-fx-font-size: 10px; -fx-text-fill: #9A8A7A;" text="GerejaCare Bot  •  Sekarang" />
                                    <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 4 18 18 18; -fx-padding: 14 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 2, 2);">
                                        <Label style="-fx-font-size: 13px; -fx-text-fill: #1A3A2A; -fx-font-weight: bold;" text="Shalom! 🙏 Selamat datang di layanan informasi GerejaCare." wrapText="true" />
                                        <Label style="-fx-font-size: 13px; -fx-text-fill: #3D5045; -fx-padding: 6 0 0 0;" text="Saya siap membantu Anda mendapatkan informasi tentang pelayanan gerejawi. Silakan pilih layanan yang Anda butuhkan dari menu di bawah ini:" wrapText="true" />
                                    </VBox>

                                    <!-- Quick Reply Buttons -->
                                    <FlowPane hgap="8" style="-fx-padding: 4 0 0 0;" vgap="8">
                                        <Button fx:id="btnPembaptisan" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A3A2A; -fx-font-size: 11px; -fx-background-radius: 16; -fx-border-color: #C8DDD0; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 6 14; -fx-cursor: hand;" text="💧 Pembaptisan" />
                                        <Button fx:id="btnPernikahan" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A3A2A; -fx-font-size: 11px; -fx-background-radius: 16; -fx-border-color: #C8DDD0; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 6 14; -fx-cursor: hand;" text="💍 Pernikahan" />
                                        <Button fx:id="btnSidi" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A3A2A; -fx-font-size: 11px; -fx-background-radius: 16; -fx-border-color: #C8DDD0; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 6 14; -fx-cursor: hand;" text="📖 SIDI" />
                                        <Button fx:id="btnKonseling" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A3A2A; -fx-font-size: 11px; -fx-background-radius: 16; -fx-border-color: #C8DDD0; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 6 14; -fx-cursor: hand;" text="🤝 Konseling" />
                                        <Button fx:id="btnJadwal" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1A3A2A; -fx-font-size: 11px; -fx-background-radius: 16; -fx-border-color: #C8DDD0; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 6 14; -fx-cursor: hand;" text="📅 Jadwal" />
                                    </FlowPane>
                                </VBox>
                            </HBox>

                        </VBox>
                    </ScrollPane>

                    <!-- ── Input Area ── -->
                    <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #E2DAD0; -fx-border-width: 1 0 0 0; -fx-padding: 16 24;">

                        <!-- Quick Actions Row -->
                        <HBox spacing="8" style="-fx-padding: 0 0 12 0;" />

                        <!-- Message Input Row -->
                        <HBox alignment="CENTER" spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #F5F0EB; -fx-background-radius: 24; -fx-padding: 10 16; -fx-border-color: #D4C9BC; -fx-border-radius: 24; -fx-border-width: 1.5;" HBox.hgrow="ALWAYS">
                                <TextArea fx:id="messageInput" maxHeight="80" prefRowCount="1" promptText="Ketik pertanyaan Anda di sini..." style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 13px; -fx-text-fill: #1A3A2A; -fx-prompt-text-fill: #A09080;" wrapText="true" HBox.hgrow="ALWAYS" />
                            </HBox>

                            <!-- Send Button -->
                            <Button onAction="#sendMessage" prefHeight="48" prefWidth="74.0" style="-fx-background-color: #1A3A2A; -fx-background-radius: 50; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(26,58,42,0.3), 10, 0, 0, 3);">
                                <graphic>
                                    <Label style="-fx-text-fill: #D4A843; -fx-font-size: 18px;" text="➤" />
                                </graphic>
                            </Button>
                        </HBox>
                    </VBox>

                </VBox>

                <!-- ═══════════════════════════════════════════ -->
                <!--              RIGHT PANEL                   -->
                <!-- ═══════════════════════════════════════════ -->
                <VBox prefWidth="280" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2DAD0; -fx-border-width: 0 0 0 1;">

                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                        <VBox spacing="0">

                            <Label style="-fx-text-fill: #9A8A7A; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 14 16 8 16; -fx-font-family: 'Verdana';" text="MENDATANG" />

                            <!-- Notif Card 1 -->
                            <VBox style="-fx-background-color: #FFF8EC; -fx-border-color: #F0E8D8 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 12 16;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane minHeight="36" minWidth="36">
                                        <Circle radius="18" style="-fx-fill: #D4A843;" />
                                        <Label style="-fx-font-size: 14px;" text="💍" />
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Kelas Pra-Nikah" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Sabtu • 09.00 WIB" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Ruang Serbaguna Lt.2" />
                                    </VBox>
                                    <Label style="-fx-text-fill: #E07A30; -fx-font-size: 10px;" text="●" />
                                </HBox>
                            </VBox>

                            <!-- Notif Card 2 -->
                            <VBox style="-fx-background-color: #EEF5EE; -fx-border-color: #DFE8DF transparent; -fx-border-width: 0 0 1 0; -fx-padding: 12 16;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane minHeight="36" minWidth="36">
                                        <Circle radius="18" style="-fx-fill: #2D5A3D;" />
                                        <Label style="-fx-font-size: 14px;" text="📖" />
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Kelas Persiapan SIDI" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Minggu • 11.00 WIB" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Aula Gereja Utama" />
                                    </VBox>
                                    <Label style="-fx-text-fill: #E07A30; -fx-font-size: 10px;" text="●" />
                                </HBox>
                            </VBox>

                            <!-- Notif Card 3 -->
                            <VBox style="-fx-background-color: #F0EBF5; -fx-border-color: #E8DFF0 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 12 16;">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane minHeight="36" minWidth="36">
                                        <Circle radius="18" style="-fx-fill: #6A4A8A;" />
                                        <Label style="-fx-font-size: 14px;" text="🤝" />
                                    </StackPane>
                                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Konseling Pdt. Harianto" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Selasa • 14.00 WIB" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6A5A;" text="Ruang Konseling Pastoral" />
                                    </VBox>
                                    <Label style="-fx-text-fill: #E05252; -fx-font-size: 10px;" text="●" />
                                </HBox>
                            </VBox>

                            <Label style="-fx-text-fill: #9A8A7A; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 14 16 8 16; -fx-font-family: 'Verdana';" text="BATAS PENDAFTARAN" />

                            <!-- Deadline 1 -->
                            <VBox style="-fx-background-color: #FFF0F0; -fx-background-radius: 10; -fx-border-color: #FFCCCC; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 12 16;">
                                <VBox.margin><Insets bottom="8" left="12" right="12" /></VBox.margin>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 14px;" text="⏰" />
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #C03030;" text="Baptis Maret 2024" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #A04040;" text="Tutup: 29 Februari 2024" />
                                    </VBox>
                                </HBox>
                                <ProgressBar maxWidth="Infinity" progress="0.7" style="-fx-accent: #E05252; -fx-pref-height: 6;">
                                    <VBox.margin><Insets top="8" /></VBox.margin>
                                </ProgressBar>
                                <Label style="-fx-font-size: 10px; -fx-text-fill: #C03030; -fx-padding: 4 0 0 0;" text="7 hari lagi" />
                            </VBox>

                            <!-- Deadline 2 -->
                            <VBox style="-fx-background-color: #FFFBEC; -fx-background-radius: 10; -fx-border-color: #FFE5A0; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 12 16;">
                                <VBox.margin><Insets bottom="8" left="12" right="12" /></VBox.margin>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label style="-fx-font-size: 14px;" text="⏰" />
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #9A7010;" text="SIDI April 2024" />
                                        <Label style="-fx-font-size: 10px; -fx-text-fill: #7A6010;" text="Tutup: 15 Maret 2024" />
                                    </VBox>
                                </HBox>
                                <ProgressBar maxWidth="Infinity" progress="0.35" style="-fx-accent: #D4A843; -fx-pref-height: 6;">
                                    <VBox.margin><Insets top="8" /></VBox.margin>
                                </ProgressBar>
                                <Label style="-fx-font-size: 10px; -fx-text-fill: #9A7010; -fx-padding: 4 0 0 0;" text="23 hari lagi" />
                            </VBox>

                            <Label style="-fx-text-fill: #9A8A7A; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 14 16 8 16; -fx-font-family: 'Verdana';" text="INFO GEREJA" />

                            <VBox spacing="8" style="-fx-padding: 4 12 16 12;">
                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #F5F0EB; -fx-background-radius: 10; -fx-padding: 10 14;">
                                    <Label style="-fx-font-size: 13px;" text="📞" />
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Sekretariat Gereja" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #5A6A5E;" text="(021) 123-4567" />
                                    </VBox>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #F5F0EB; -fx-background-radius: 10; -fx-padding: 10 14;">
                                    <Label style="-fx-font-size: 13px;" text="🕒" />
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A3A2A;" text="Jam Operasional" />
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #5A6A5E;" text="Sen–Jum: 08.00–16.00" />
                                    </VBox>
                                </HBox>
                            </VBox>

                        </VBox>
                    </ScrollPane>

                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
